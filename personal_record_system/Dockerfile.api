FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY personal_record_system ./personal_record_system

ENV PYTHONPATH=/app/personal_record_system

EXPOSE 8000

CMD [uvicorn, personal_record_system.app.main:app, --host, 0.0.0.0, --port, 8000]

# PhotoProject secrets — copy to .env (gitignored) and fill in.
# ConfigManager loads .env from the working directory at startup.

# Azure Computer Vision (OCR)
AZURE_COMPUTER_VISION_KEY=
AZURE_COMPUTER_VISION_ENDPOINT=

# OpenAI (parser)
OPENAI_API_KEY=

# Discogs (enrichment) — generate at https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

# MusicBrainz (enrichment) — required user-agent string
MUSICBRAINZ_USER_AGENT=RecordCatalogApp/1.0 (your-email@example.com)
